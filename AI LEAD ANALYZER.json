    {
      "parameters": {
        "jsCode": "let score = 0;\n\n// Revenue\nconst revenue = $json[\"Monthly Revenue\"];\n\nif (revenue === \"$20k-$100k\") score += 40;\nelse if (revenue === \"$5k-$20k\") score += 25;\nelse score += 10;\n\n// Timeline\nconst timeline = $json[\"  How soon do you want a solution?  \"];\n\nif (timeline === \"Immediately\") score += 30;\nelse if (timeline === \"Within 30 days\") score += 20;\nelse score += 10;\n\n// Company Size\nconst size = $json[\"Company size\"];\n\nif (size === \"201+\") score += 25;\nelse if (size === \"51-200\") score += 20;\nelse if (size === \"11-50\") score += 15;\nelse score += 10;\n\n// Status\nlet status = \"cold\";\n\nif (score >= 80) status = \"hot\";\nelse if (score >= 50) status = \"warm\";\n\nreturn [{\n  json: {\n    ...$json,\n    lead_score: score,\n    lead_status: status\n  }\n}];"
      },
